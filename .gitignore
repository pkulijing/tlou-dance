# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual env
.venv/
venv/
env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/
.cache/

# 注意：uv.lock 应当 commit 进 git（uv 官方推荐），所以这里不忽略

# Env files（本地真实值，不进 git）
.env
.env.local
*.local.env

# Editors / OS
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.vscode/*.log

# Claude Code 本地状态（per-user 权限、worktree 元数据等）
.claude/settings.local.json
.claude/worktrees/

# === 项目运行时数据 / 输出（per-round 子目录隔离） ===
data/
outputs/

# === 大媒体 / 模型权重通用扩展名 ===
*.mp4
*.bvh
*.fbx
*.pkl
*.pth
*.ckpt
*.blend
*.blend1
*.glb

# docs/ 资源里如有大动图也忽略（小 PNG/SVG 仍可 commit）
docs/**/assets/*.mp4
docs/**/assets/*.mov
